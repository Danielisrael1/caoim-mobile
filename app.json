{
  "expo": {
    "name": "Caoim",
    "slug": "caoim-church",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cao-icon.png",
    "scheme": "caoim",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/cao-icon.png",
      "color": "#203F9A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lukwagodaniel.caoimchurch",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#203F9A",
        "foregroundImage": "./assets/images/cao-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "org.caoimchurchuganda.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/cao-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/caoim-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "762ccd10-bce5-488d-b739-08fd40d5458d"
      }
    }
  }
}
